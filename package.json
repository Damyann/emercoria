{
  "name": "game",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm exec concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --dir apps/frontend dev",
    "dev:backend": "pnpm --dir apps/backend start:dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
